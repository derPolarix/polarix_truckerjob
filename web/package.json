{
  "name": "polarix_truckerjob",
  "version": "1.0",
  "scripts": {
    "dev": "vite --port 5050 --strictPort",
    "build": "npm run typecheck && vite build --emptyOutDir",
    "build:watch": "vite build --emptyOutDir --watch",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:watch": "vue-tsc --noEmit --watch",
    "preview": "vite preview --port 5051 --strictPort",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js,css}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,js,css}\""
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@iconify/vue": "^4.3.0",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.14",
    "pinia": "^3.0.1",
    "vue": "^3.2.45",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.2.1",
    "vue-tsc": "^2.1.10"
  }
}
